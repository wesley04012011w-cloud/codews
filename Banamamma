    table.insert(self.ThemedElements, topIcon)

    local titleFrame = Instance.new("Frame", topBar)
    titleFrame.Size = UDim2.new(1, -150, 1, 0)
    titleFrame.Position = UDim2.new(0, 60, 0, 0)
    titleFrame.BackgroundTransparency = 1

    local n = Instance.new("TextLabel", titleFrame)
    n.Size = UDim2.new(1, 0, 0.5, 0)
    n.Position = UDim2.new(0, 0, 0.15, 0)
    n.Text = uiName:upper()
    n.TextColor3 = self.Colors.ACCENT_WHITE
    n.Font = Enum.Font.GothamBold
    n.TextSize = 16
    n.BackgroundTransparency = 1
    n.TextXAlignment = Enum.TextXAlignment.Left

    local v = Instance.new("TextLabel", titleFrame)
    v.Size = UDim2.new(1, 0, 0.5, 0)
    v.Position = UDim2.new(0, 0, 0.45, 0)
    v.Text = "version " .. uiVersion
    v.TextColor3 = Color3.fromRGB(120, 120, 120)
    v.Font = Enum.Font.GothamMedium
    v.TextSize = 10
    v.BackgroundTransparency = 1
    v.TextXAlignment = Enum.TextXAlignment.Left

    local isMinimized = false
    local minBtn = Instance.new("TextButton", topBar)
    minBtn.Size = UDim2.new(0, 30, 0, 30)
    minBtn.Position = UDim2.new(1, -40, 0.5, -15)
    minBtn.BackgroundColor3 = self.Colors.DARK_GREY
    minBtn.Text = "−"
    minBtn.TextColor3 = Color3.new(1,1,1)
    createCorner(minBtn, 8)
    
    minBtn.MouseButton1Click:Connect(function()
        isMinimized = not isMinimized
        local targetH = isMinimized and 60 or 320
        TweenService:Create(main, self.TweenInfoSlow, {Size = UDim2.new(0, 450, 0, targetH)}):Play()
        minBtn.Text = isMinimized and "+" or "−"
    end)

    -- Função do Botão Flutuante (Abrir/Fechar UI Completa)
    local uiOpen = true
    toggleBtn.MouseButton1Click:Connect(function()
        uiOpen = not uiOpen
        if uiOpen then
            main.Visible = true
            local finalHeight = isMinimized and 60 or 320
            TweenService:Create(main, self.TweenInfoSlow, {GroupTransparency = 0, Size = UDim2.new(0, 450, 0, finalHeight)}):Play()
        else
            local t = TweenService:Create(main, self.TweenInfoFast, {GroupTransparency = 1, Size = UDim2.new(0, 400, 0, 280)})
            t:Play()
            t.Completed:Connect(function() if not uiOpen then main.Visible = false end end)
        end
    end)

    local sidebar = Instance.new("Frame", main)
    sidebar.Size = UDim2.new(0, 120, 1, -60)
    sidebar.Position = UDim2.new(0, 0, 0, 60)
    sidebar.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    createCorner(sidebar, 10)

    self.Container = Instance.new("Frame", main)
    self.Container.Size = UDim2.new(1, -135, 1, -75)
    self.Container.Position = UDim2.new(0, 130, 0, 70)
    self.Container.BackgroundTransparency = 1

    self.TabList = Instance.new("ScrollingFrame", sidebar)
    self.TabList.Size = UDim2.new(1, 0, 1, -10)
    self.TabList.BackgroundTransparency = 1
    self.TabList.ScrollBarThickness = 0
    
    local listLayout = Instance.new("UIListLayout", self.TabList)
    listLayout.Padding = UDim.new(0, 5)
    listLayout.SortOrder = Enum.SortOrder.LayoutOrder

    -- ==========================================
    -- ABA NATIVA DE CONFIGURAÇÕES (GERADA PELA PRÓPRIA LIBRARY)
    -- ==========================================
    task.spawn(function()
        local SettingsTab = self:CreateTab("⚙ Settings")
        -- Ajustamos o LayoutOrder para 999 para garantir que fique lá em baixo!
        for _, child in pairs(self.TabList:GetChildren()) do
            if child:IsA("TextButton") and child.Text == "⚙ Settings" then
                child.LayoutOrder = 999
            end
        end

        local colorNames = {}
        for colorName, _ in pairs(self.Colors.Palette) do
            table.insert(colorNames, colorName)
        end

        SettingsTab:CreateDropdown("Theme Color", colorNames, function(selected)
            local hexColor = self.Colors.Palette[selected]
            if hexColor then self:SetTheme(hexColor) end
        end)

        SettingsTab:CreateToggle("RGB Rainbow Mode", function(state)
            self:ToggleRGB(state)
        end)
        
        -- Truque para a aba nativa NÃO ser a aba selecionada por padrão 
        -- (Isso garante que a primeira aba criada pelo usuário seja a principal)
        self._firstTab = false 
    end)
    -- ==========================================

    return self
end

function Library:CreateTab(name)
    local btn = Instance.new("TextButton", self.TabList)
    btn.Size = UDim2.new(0.9, 0, 0, 32)
    btn.BackgroundColor3 = self.Colors.DARK_GREY
    btn.Text = name
    btn.TextColor3 = Color3.fromRGB(180, 180, 180)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 11
    createCorner(btn, 6)

    local content = Instance.new("ScrollingFrame", self.Container)
    content.Size = UDim2.new(1, 0, 1, 0)
    content.BackgroundTransparency = 1
    content.Visible = false
    content.ScrollBarThickness = 2
    content.ScrollBarImageColor3 = self.Colors.PRIMARY_ACCENT
    local l = Instance.new("UIListLayout", content)
    l.Padding = UDim.new(0, 8)
    l.HorizontalAlignment = Enum.HorizontalAlignment.Center
    table.insert(self.ThemedElements, content)

    btn.MouseButton1Click:Connect(function()
        for _, v in pairs(self.Container:GetChildren()) do
            if v:IsA("ScrollingFrame") then v.Visible = false end
        end
        content.Visible = true
        content.Position = UDim2.new(0, 0, 0, 15)
        TweenService:Create(content, self.TweenInfoFast, {Position = UDim2.new(0, 0, 0, 0)}):Play()
    end)

    if not self._firstTab then 
        self._firstTab = true 
        content.Visible = true 
    end

    local tab = {}
    
    function tab:CreateButton(text, cb)
        local b = Instance.new("TextButton", content)
        b.Size = UDim2.new(0.95, 0, 0, 38)
        b.BackgroundColor3 = Library.Colors.DARK_GREY
        b.Text = text
        b.TextColor3 = Color3.new(1,1,1)
        b.Font = Enum.Font.GothamSemibold
        createCorner(b, 6)
        
        b.MouseButton1Click:Connect(function()
            TweenService:Create(b, TweenInfo.new(0.1), {Size = UDim2.new(0.92, 0, 0, 35)}):Play()
            task.delay(0.1, function() TweenService:Create(b, TweenInfo.new(0.1), {Size = UDim2.new(0.95, 0, 0, 38)}):Play() end)
            cb()
        end)
    end
    
    function tab:CreateToggle(text, cb)
        local s = false
        local tBtn = Instance.new("TextButton", content)
        tBtn.Size = UDim2.new(0.95, 0, 0, 38)
        tBtn.BackgroundColor3 = Library.Colors.DARK_GREY
        tBtn.Text = "  " .. text
        tBtn.TextXAlignment = Enum.TextXAlignment.Left
        tBtn.TextColor3 = Color3.new(1,1,1)
        createCorner(tBtn, 6)

        local box = Instance.new("Frame", tBtn)
        box.Size = UDim2.new(0, 36, 0, 18)
        box.Position = UDim2.new(1, -45, 0.5, -9)
        box.BackgroundColor3 = Color3.fromRGB(40,40,40)
        createCorner(box, 10)

        local dot = Instance.new("Frame", box)
        dot.Name = "Fill"
        dot.Size = UDim2.new(0, 14, 0, 14)
        dot.Position = UDim2.new(0, 2, 0.5, -7)
        dot.BackgroundColor3 = Library.Colors.PRIMARY_ACCENT
        createCorner(dot, 10)
        table.insert(Library.ThemedElements, dot)

        tBtn.MouseButton1Click:Connect(function()
            s = not s
            TweenService:Create(dot, Library.TweenInfoFast, {Position = s and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)}):Play()
            cb(s)
        end)
    end

    function tab:CreateDropdown(text, list, cb)
        local open = false
        local dFrame = Instance.new("Frame", content)
        dFrame.Size = UDim2.new(0.95, 0, 0, 38)
        dFrame.BackgroundColor3 = Library.Colors.DARK_GREY
        dFrame.ClipsDescendants = true
        createCorner(dFrame, 6)

        local dBtn = Instance.new("TextButton", dFrame)
        dBtn.Size = UDim2.new(1, 0, 0, 38)
        dBtn.Text = "  " .. text
        dBtn.TextXAlignment = Enum.TextXAlignment.Left
        dBtn.TextColor3 = Color3.new(1,1,1)
        dBtn.BackgroundTransparency = 1

        local arrow = Instance.new("TextLabel", dBtn)
        arrow.Name = "Arrow"
        arrow.Size = UDim2.new(0, 30, 1, 0)
        arrow.Position = UDim2.new(1, -35, 0, 0)
        arrow.BackgroundTransparency = 1
        arrow.Text = "▼"
        arrow.TextColor3 = Library.Colors.PRIMARY_ACCENT
        arrow.TextSize = 12
        table.insert(Library.ThemedElements, arrow)

        dBtn.MouseButton1Click:Connect(function()
            open = not open
            TweenService:Create(arrow, Library.TweenInfoFast, {Rotation = open and 180 or 0}):Play()
            TweenService:Create(dFrame, Library.TweenInfoFast, {Size = open and UDim2.new(0.95, 0, 0, 38 + (#list * 30)) or UDim2.new(0.95, 0, 0, 38)}):Play()
        end)

        for i, item in pairs(list) do
            local it = Instance.new("TextButton", dFrame)
            it.Size = UDim2.new(0.95, 0, 0, 25)
            it.Position = UDim2.new(0.025, 0, 0, 40 + ((i-1)*28))
            it.Text = item
            it.BackgroundColor3 = Color3.fromRGB(35,35,35)
            it.TextColor3 = Color3.fromRGB(200,200,200)
            createCorner(it, 4)
            it.MouseButton1Click:Connect(function()
                cb(item); dBtn.Text = "  " .. text .. ": " .. item
                open = false
                TweenService:Create(arrow, Library.TweenInfoFast, {Rotation = 0}):Play()
                TweenService:Create(dFrame, Library.TweenInfoFast, {Size = UDim2.new(0.95, 0, 0, 38)}):Play()
            end)
        end
    end

    return tab
end

return Library
