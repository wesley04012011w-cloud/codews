local RunService = game:GetService("RunService")

-- [ FUNÇÕES AUXILIARES ] --
local function createCorner(obj, r)
    local c = Instance.new("UICorner", obj)
    c.CornerRadius = UDim.new(0, r or 10)
    return c
end

local function createStroke(obj, color, thickness)
    local s = Instance.new("UIStroke", obj)
    s.Color = color
    s.Thickness = thickness or 1.2
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    table.insert(Library.ThemedElements, s)
    return s
end

local function makeDraggable(frame, handle)
    local dragging, dragInput, dragStart, startPos
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    handle.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

local function rotateIcon(label)
    task.spawn(function()
        while label and label.Parent do
            label.Rotation = label.Rotation + 3
            task.wait()
        end
    end)
end

-- [ SISTEMA DE TEMA ] --
function Library:SetTheme(color)
    self.Colors.PRIMARY_ACCENT = color
    for _, obj in pairs(self.ThemedElements) do
        pcall(function()
            if obj:IsA("UIStroke") then
                obj.Color = color
            elseif obj:IsA("Frame") and obj.Name == "Fill" then
                obj.BackgroundColor3 = color
            elseif obj:IsA("TextLabel") and obj.Name == "Icon" then
                obj.TextColor3 = color
            elseif obj:IsA("ScrollingFrame") then
                obj.ScrollBarImageColor3 = color
            elseif obj:IsA("TextLabel") and (obj.Name == "FPSLabel" or obj.Name == "TitleNotify") then
                obj.TextColor3 = color
            end
        end)
    end
end

function Library:ToggleRGB(state)
    if state then
        if self.RGBConnection then self.RGBConnection:Disconnect() end
        self.RGBConnection = RunService.RenderStepped:Connect(function()
            local hue = tick() % 5 / 5
            local color = Color3.fromHSV(hue, 1, 1)
            self:SetTheme(color)
        end)
    else
        if self.RGBConnection then 
            self.RGBConnection:Disconnect() 
            self.RGBConnection = nil
        end
    end
end

-- [ NOTIFICAÇÃO ] --
function Library:Notify(title, text, duration)
    local parent = CoreGui:FindFirstChild("BitcodeLibrary")
    if not parent then return end
    local container = parent:FindFirstChild("NotifyContainer")
    if not container then
        container = Instance.new("Frame", parent)
        container.Name = "NotifyContainer"
        container.Size = UDim2.new(0, 260, 1, -20)
        container.Position = UDim2.new(1, -270, 0, 10)
        container.BackgroundTransparency = 1
        Instance.new("UIListLayout", container).VerticalAlignment = Enum.VerticalAlignment.Bottom
    end

    local frame = Instance.new("Frame", container)
    frame.Size = UDim2.new(1, 0, 0, 0)
    frame.BackgroundColor3 = self.Colors.BACKGROUND_BLACK
    frame.ClipsDescendants = true
    createCorner(frame, 8)
    createStroke(frame, self.Colors.PRIMARY_ACCENT, 1.2)

    local tl = Instance.new("TextLabel", frame)
    tl.Name = "TitleNotify"
    tl.Size = UDim2.new(1, -10, 0, 18)
    tl.Position = UDim2.new(0, 8, 0, 4)
    tl.Text = title
    tl.TextColor3 = self.Colors.PRIMARY_ACCENT
    tl.Font = Enum.Font.GothamBold
    tl.TextSize = 12
    tl.BackgroundTransparency = 1
    tl.TextXAlignment = Enum.TextXAlignment.Left
    table.insert(self.ThemedElements, tl)

    local desc = Instance.new("TextLabel", frame)
    desc.Size = UDim2.new(1, -10, 0, 30)
    desc.Position = UDim2.new(0, 8, 0, 20)
    desc.Text = text
    desc.TextColor3 = self.Colors.ACCENT_WHITE
    desc.Font = Enum.Font.Gotham
    desc.TextSize = 11
    desc.BackgroundTransparency = 1
    desc.TextWrapped = true
    desc.TextXAlignment = Enum.TextXAlignment.Left

    TweenService:Create(frame, TweenInfo.new(0.4), {Size = UDim2.new(1, 0, 0, 55)}):Play()
    task.delay(duration or 3, function()
        local t = TweenService:Create(frame, TweenInfo.new(0.4), {Size = UDim2.new(1, 0, 0, 0)})
        t:Play()
        t.Completed:Connect(function() frame:Destroy() end)
    end)
end

