        HIGHLIGHT = Color3.fromRGB(40, 40, 40),
        TOPBAR = Color3.fromRGB(18, 18, 18),

        -- Nova Paleta de Cores (Para usar em SetTheme ou outros elementos)
        Palette = {
            RED = Color3.fromRGB(255, 75, 75),
            GREEN = Color3.fromRGB(75, 255, 120),
            BLUE = Color3.fromRGB(75, 150, 255),
            PURPLE = Color3.fromRGB(170, 85, 255),
