    toggleBtn.Size = UDim2.new(0, 50, 0, 50)
    toggleBtn.Position = UDim2.new(0, 20, 0.15, 0)
    toggleBtn.BackgroundColor3 = self.Colors.TOPBAR
    toggleBtn.Text = ""
    createCorner(toggleBtn, 25)
    createStroke(toggleBtn, self.Colors.PRIMARY_ACCENT, 1.5)
    makeDraggable(toggleBtn, toggleBtn)

    local btnIcon = Instance.new("TextLabel", toggleBtn)
